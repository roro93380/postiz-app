POSTIZ_DOMAIN=postiz.example.com
POSTIZ_EMAIL=admin@example.com

# Core application URLs
MAIN_URL=https://postiz.example.com
FRONTEND_URL=https://postiz.example.com
NEXT_PUBLIC_BACKEND_URL=https://postiz.example.com/api
BACKEND_INTERNAL_URL=http://127.0.0.1:3000

# Core infrastructure
JWT_SECRET=replace-with-a-long-random-secret
POSTIZ_DB_USER=postiz-user
POSTIZ_DB_PASSWORD=replace-with-db-password
POSTIZ_DB_NAME=postiz-prod
DATABASE_URL=postgresql://postiz-user:replace-with-db-password@postiz-postgres:5432/postiz-prod
REDIS_URL=redis://postiz-redis:6379
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=replace-with-temporal-db-password
TEMPORAL_DB_NAME=temporal
NODE_ENV=production
IS_GENERAL=true
DISABLE_REGISTRATION=true
API_LIMIT=30
NX_ADD_PLUGINS=false

# Storage
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# Optional Cloudflare R2 storage
# STORAGE_PROVIDER=cloudflare
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ACCESS_KEY=
# CLOUDFLARE_SECRET_ACCESS_KEY=
# CLOUDFLARE_BUCKETNAME=
# CLOUDFLARE_BUCKET_URL=
# CLOUDFLARE_REGION=auto

# Optional monitoring and email
# NEXT_PUBLIC_SENTRY_DSN=
# RESEND_API_KEY=
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME=Postiz

# TikTok integration
# Use production TikTok app credentials here. Sandbox credentials are not suitable
# for real scheduled posting on a public production deployment.
TIKTOK_CLIENT_ID=replace-with-tiktok-client-id
TIKTOK_CLIENT_SECRET=replace-with-tiktok-client-secret

# Other providers can stay empty until needed
X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
BEEHIIVE_API_KEY=
BEEHIIVE_PUBLICATION_ID=
THREADS_APP_ID=
THREADS_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN_ID=
SLACK_ID=
SLACK_SECRET=
SLACK_SIGNING_SECRET=
MASTODON_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# Optional billing and AI
OPENAI_API_KEY=
NEXT_PUBLIC_DISCORD_SUPPORT=
NEXT_PUBLIC_POLOTNO=
FEE_AMOUNT=0.05
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_SIGNING_KEY=
STRIPE_SIGNING_KEY_CONNECT=