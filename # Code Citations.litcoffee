import { GetOrgFromRequest } from '@gitroom/nestjs-libraries/user/org.from.request';
import { ApiTags } from '@nestjs/swagger';
import { DashboardService } from '@gitroom/nestjs-libraries/database/prisma/dashboard/dashboard.service';

@ApiTags('Dashboard')
@Controller('/dashboard')
export class DashboardController {
  constructor(private _dashboardService: DashboardService) {}

  @Get('/summary')
  async getSummary(
    @GetOrgFromRequest() org: Organization,
    @Query('date') date?: string
  ) {
    return this._dashboardService.getDashboardSummary(org.id, date);
  }
}
```

---

## 📁 Fichier 2 : Backend Service
**Créer** : `libraries/nestjs-libraries/src/database/prisma/dashboard/dashboard.service.ts`

```typescript
import { Injectable } from '@nestjs/common';
import { PrismaRepository } from '@gitroom/nestjs-libraries/database/prisma/prisma.service';
import { IntegrationService } from '@gitroom/nestjs-libraries/database/prisma/integrations/integration.service';
import dayjs from 'dayjs';

@Injectable()
export class DashboardService {
  constructor(
    private _prisma: PrismaRepository,
    private _integrationService: IntegrationService
  ) {}

  async getDashboardSummary(orgId: string, date?: string) {
    const now = dayjs();
    const startOfMonth = now.startOf('month').toDate();

    const [upcomingPosts, recentPosts, postStats, integrations] =
      await Promise.all([
        // 5 prochains posts en queue
        this._prisma.model.post.findMany({
          where: {
            organizationId: orgId,
            state: 'QUEUE',
            deletedAt: null,
            parentPostId: null,
            publishDate: { gte: new Date() },
          },
          orderBy: { publishDate: 'asc' },
          take: 5,
          select: {
            id: true,
            content: true,
            publishDate: true,
            state: true,
            image: true,
            integration: {
              select: {
                id: true,
                name: true,
                providerIdentifier: true,
                picture: true,
              },
            },
          },
        }),
        // 5 derniers posts publiés
        this._prisma.model.post.findMany({
          where: {
            organizationId: orgId,
            state: 'PUBLISHED',
            deletedAt: null,
            parentPostId: null,
          },
          orderBy: { publishDate: 'desc' },
          take: 5,
          select: {
            id: true,
            content: true,
            publishDate: true,
            state: true,
            image: true,
            releaseURL: true,
            integration: {
              select: {
                id: true,
                name: true,
                providerIdentifier: true,
                picture: true,
              },
            },
          },
        }),
        // Compteurs
        Promise.all([
          this._prisma.model.post.count({
            where: {
              organizationId: orgId,
              state: 'PUBLISHED',
              deletedAt: null,
              parentPostId: null,
              publishDate: { gte: startOfMonth },
            },
          }),
          this._prisma.model.post.count({
            where: {
              organizationId: orgId,
              state: 'QUEUE',
              deletedAt: null,
              parentPostId: null,
            },
          }),
          this._prisma.model.post.count({
            where: {
              organizationId: orgId,
              state: 'DRAFT',
              deletedAt: null,
              parentPostId: null,
            },
          }),
        ]),
        // Intégrations actives
        this._prisma.model.integration.findMany({
          where: {
            organizationId: orgId,
            deletedAt: null,
            disabled: false,
            type: 'social',
          },
          select: {
            id: true,
            name: true,
            providerIdentifier: true,
            picture: true,
          },
        }),
      ]);

    // Posts pour le mini-calendrier (7 prochains jours)
    const weekStart = now.startOf('day').toDate();
    const weekEnd = now.add(6, 'day').endOf('day').toDate();

    const calendarPosts = await this._prisma.model.post.findMany({
      where: {
        organizationId: orgId,
        deletedAt: null,
        parentPostId: null,
        state: { in: ['QUEUE', 'PUBLISHED'] },
        publishDate: { gte: weekStart, lte: weekEnd },
      },
      orderBy: { publishDate: 'asc' },
      select: {
        id: true,
        content: true,
        publishDate: true,
        state: true,
        image: true,
        integration: {
          select: {
            id: true,
            name: true,
            providerIdentifier: true,
            picture: true,
          },
        },
      },
    });

    return {
      upcomingPosts,
      recentPosts,
      calendarPosts,
      postStats: {
        publishedThisMonth: postStats[0],
        queued: postStats[1],
        drafts: postStats[2],
      },
      integrations,
      totalIntegrations: integrations.length,
    };
  }
}
```

