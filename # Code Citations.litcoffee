```tsx
'use client';

import { FC } from 'react';
import dayjs from 'dayjs';
import relativeTime from 'dayjs/plugin/relativeTime';
import Link from 'next/link';
import { DashboardCard } from './dashboard-card';
import ImageWithFallback from '@gitroom/react/helpers/image.with.fallback';

dayjs.extend(relativeTime);

interface QueuePost {
  id: string;
  content: string;
  publishDate: string;
  state: string;
  image?: string | null;
  integration: {
    id: string;
    name: string;
    providerIdentifier: string;
    picture: string;
  };
}

export const PublicationQueueWidget: FC<{
  upcomingPosts: QueuePost[];
}> = ({ upcomingPosts }) => {
  return (
    <DashboardCard
      title="Publication Queue"
      accentColor="red"
      action={
        <Link
          href="/launches"
          className="text-[12px] text-[#E8243C] hover:text-[#E8243C]/80 font-medium transition-colors"
        >
          View all →
        </Link>
      }
    >
      {upcomingPosts.length === 0 ? (
        <div className="text-center py-6 text-newTextColor/40 text-[13px]">
          No posts in queue
        </div>
      ) : (
        <div className="flex flex-col gap-2">
          {upcomingPosts.map((post) => (
            <div
              key={post.id}
              className="flex items-center gap-3 p-2.5 rounded-lg bg-newBgColor/30 border border-newBorder/30 hover:border-newBorder/60 transition-colors"
            >
              <div className="w-8 h-8 rounded-full overflow-hidden flex-shrink-0 ring-2 ring-[#00D4FF]/30">
                <ImageWithFallback
                  src={post.integration.picture}
                  alt={post.integration.name}
                  width={32}
                  height={32}
                  fallbackSrc="/no-picture.png"
                />
              </div>
              <div className="flex-1 min-w-0">
                <p className="text-[13px] text-newTextColor truncate leading-tight">
                  {post.content
                    ? post.content.replace(/<[^>]*>/g, '').slice(0, 60) +
                      (post.content.length > 60 ? '...' : '')
                    : 'Untitled post'}
                </p>
                <div className="flex items-center gap-2 mt-0.5">
                  <span className="text-[10px] text-newTextColor/40 font-medium">
                    {post.integration.name}
                  </span>
                  <span className="text-[10px] text-newTextColor/20">•</span>
                  <span className="text-[10px] text-[#00D4FF]/70 font-medium">
                    {dayjs(post.publishDate).format('MMM DD, HH:mm')}
                  </span>
                </div>
              </div>
              <div className="flex-shrink-0">
                <span className="inline-block w-2 h-2 rounded-full bg-[#00D4FF] animate-pulse" />
              </div>
            </div>
          ))}
        </div>
      )}
    </DashboardCard>
  );
};
```

