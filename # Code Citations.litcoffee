'use client';

import { FC, ReactNode } from 'react';
import clsx from 'clsx';

export const DashboardCard: FC<{
  title: string;
  accentColor?: 'cyan' | 'red' | 'green' | 'purple';
  action?: ReactNode;
  children: ReactNode;
  className?: string;
}> = ({ title, accentColor = 'cyan', action, children, className }) => {
  const accentClasses = {
    cyan: 'border-t-[#00D4FF]',
    red: 'border-t-[#E8243C]',
    green: 'border-t-[#32d583]',
    purple: 'border-t-[rgb(97,43,211)]',
  };

  return (
    <div
      className={clsx(
        'bg-newBgColorInner border border-newBorder rounded-xl overflow-hidden border-t-2',
        accentClasses[accentColor],
        className
      )}
    >
      <div className="flex items-center justify-between px-5 pt-4 pb-3">
        <h3 className="text-[15px] font-semibold text-newTextColor">
          {title}
        </h3>
        {action}
      </div>
      <div className="px-5 pb-4">{children}</div>
    </div>
  );
};
