```tsx
'use client';

import { FC, useCallback } from 'react';
import useSWR from 'swr';
import { useFetch } from '@gitroom/helpers/utils/custom.fetch';
import { DashboardCard } from './dashboard-card';

export const TrendsWidget: FC = () => {
  const fetch = useFetch();

  const load = useCallback(async () => {
    return await (await fetch('/analytics')).json();
  }, []);

  const { data } = useSWR('/dashboard-analytics', load, {
    revalidateOnFocus: false,
    revalidateOnReconnect: false,
    revalidateIfStale: false,
    refreshWhenOffline: false,
    refreshWhenHidden: false,
  });

  const trending = data?.trending;

  return (
    <DashboardCard title="Trending Insights" accentColor="purple">
      {!trending?.last && !trending?.next ? (
        <div className="flex flex-col items-center justify-center py-6 gap-3">
          <div className="w-12 h-12 rounded-full bg-[rgb(97,43,211)]/10 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgb(97,43,211)" strokeWidth="2">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
            </svg>
          </div>
          <p className="text-[13px] text-newTextColor/40 text-center">
            Trending data will appear here when available
          </p>
        </div>
      ) : (
        <div className="flex flex-col gap-3">
          {trending?.last && (
            <div className="p-3 rounded-lg bg-newBgColor/30 border border-newBorder/30">
              <div className="flex items-center gap-2 mb-1.5">
                <span className="inline-block w-2 h-2 rounded-full bg-[#32d583]" />
                <span className="text-[11px] text-newTextColor/50 font-medium uppercase tracking-wider">
                  Last trending
                </span>
              </div>
              <p className="text-[14px] text-newTextColor font-medium">
                {trending.last}
              </p>
            </div>
          )}
          {trending?.next && (
            <div className="p-3 rounded-lg bg-[#00D4FF]/5 border border-[#00D4FF]/20">
              <div className="flex items-center gap-2 mb-1.5">
                <span className="inline-block w-2 h-2 rounded-full bg-[#00D4FF] animate-pulse" />
                <span className="text-[11px] text-[#00D4FF]/70 font-medium uppercase tracking-wider">
                  Predicted next
                </span>
              </div>
              <p className="text-[14px] text-newTextColor font-medium">
                {trending.next}
              </p>
            </div>
          )}
        </div>
      )}
    </DashboardCard>
  );
};
```

---

## 📁 Fichier 12 : DashboardComponent principal
**Créer** : `apps/frontend/src/components/dashboard/dashboard.component.tsx`

```tsx
'use client';

import { FC } from 'react';
import { useDashboardSummary } from './use-dashboard.hook';
import { KeyStatsWidget } from './widgets/key-stats.widget';
import { MiniCalendarWidget } from './widgets/mini-calendar.widget';
import { PublicationQueueWidget } from './widgets/publication-queue.widget';
import { RecentPostsWidget } from './widgets/recent-posts.widget';
import { TrendsWidget } from './widgets/trends.widget';
import { LoadingComponent } from '@gitroom/frontend/components/layout/loading';

export const DashboardComponent: FC = () => {
  const { data, isLoading } = useDashboardSummary();

  if (isLoading || !data) {
    return <LoadingComponent />;
  }

  return (
    <div className="flex flex-col gap-5 p-4 max-w-[1400px] mx-auto w-full">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-[28px] font-bold text-newTextColor tracking-tight">
            Dashboard
          </h1>
          <p className="text-[14px] text-newTextColor/50 mt-0.5">
            Overview of your social media activity
          </p>
        </div>
      </div>

      {/* Main grid */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
        {/* Left column - 2/3 */}
        <div className="lg:col-span-2 flex flex-col gap-4">
          {/* Mini Calendar */}
          <MiniCalendarWidget calendarPosts={data.calendarPosts} />

          {/* Bottom row: Trends */}
          <TrendsWidget />
        </div>

        {/* Right column - 1/3 */}
        <div className="flex flex-col gap-4">
          {/* Key Stats */}
          <KeyStatsWidget
            postStats={data.postStats}
            totalIntegrations={data.totalIntegrations}
          />

          {/* Publication Queue */}
          <PublicationQueueWidget upcomingPosts={data.upcomingPosts} />
        </div>
      </div>

      {/* Recent Posts - full width */}
      <RecentPostsWidget recentPosts={data.recentPosts} />
    </div>
  );
};
```

