        </svg>
      ),
    },
    {
      label: 'Queued',
      value: postStats.queued,
      subtitle: 'scheduled',
      color: 'text-[#00D4FF]',
      bg: 'bg-[#00D4FF]/10',
      icon: (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
      ),
    },
    {
      label: 'Drafts',
      value: postStats.drafts,
      subtitle: 'in progress',
      color: 'text-[#9c9c9c]',
      bg: 'bg-[#9c9c9c]/10',
      icon: (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
        </svg>
      ),
    },
    {
      label: 'Channels',
      value: totalIntegrations,
      subtitle: 'connected',
      color: 'text-[#E8243C]',
      bg: 'bg-[#E8243C]/10',
      icon: (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
          <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="8.5" cy="7" r="4" />
          <line x1="20" y1="8" x2="20" y2="14" />
          <line x1="23" y1="11" x2="17" y2="11" />
        </svg>
      ),
    },
  ];

  return (
    <DashboardCard title="Key Statistics" accentColor="cyan">
      <div className="grid grid-cols-2 gap-3">
        {stats.map((stat) => (
          <div
            key={stat.label}
            className="flex items-center gap-3 p-3 rounded-lg bg-newBgColor/50 border border-newBorder/50"
          >
            <div className={`w-10 h-10 rounded-lg ${stat.bg} flex items-center justify-center ${stat.color}`}>
              {stat.icon}
            </div>
            <div>
              <div className="text-[24px] font-bold leading-tight text-newTextColor">
                {new Intl.NumberFormat().format(stat.value)}
              </div>
              <div className="text-[11px] text-newTextColor/50 font-medium">
                {stat.subtitle}
              </div>
            </div>
          </div>
        ))}
      </div>
    </DashboardCard>
  );
};
