      upcomingPosts,
      recentPosts,
      calendarPosts,
      postStats: {
        publishedThisMonth: postStats[0],
        queued: postStats[1],
        drafts: postStats[2],
      },
      integrations,
      totalIntegrations: integrations.length,
    };
  }
}
