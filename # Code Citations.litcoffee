## 📁 Fichier 12 : DashboardComponent principal
**Créer** : `apps/frontend/src/components/dashboard/dashboard.component.tsx`

```tsx
'use client';

import { FC } from 'react';
import { useDashboardSummary } from './use-dashboard.hook';
import { KeyStatsWidget } from './widgets/key-stats.widget';
import { MiniCalendarWidget } from './widgets/mini-calendar.widget';
import { PublicationQueueWidget } from './widgets/publication-queue.widget';
import { RecentPostsWidget } from './widgets/recent-posts.widget';
import { TrendsWidget } from './widgets/trends.widget';
import { LoadingComponent } from '@gitroom/frontend/components/layout/loading';

export const DashboardComponent: FC = () => {
  const { data, isLoading } = useDashboardSummary();

  if (isLoading || !data) {
    return <LoadingComponent />;
  }

  return (
    <div className="flex flex-col gap-5 p-4 max-w-[1400px] mx-auto w-full">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-[28px] font-bold text-newTextColor tracking-tight">
            Dashboard
          </h1>
          <p className="text-[14px] text-newTextColor/50 mt-0.5">
            Overview of your social media activity
          </p>
        </div>
      </div>

      {/* Main grid */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
        {/* Left column - 2/3 */}
        <div className="lg:col-span-2 flex flex-col gap-4">
          {/* Mini Calendar */}
          <MiniCalendarWidget calendarPosts={data.calendarPosts} />

          {/* Bottom row: Trends */}
          <TrendsWidget />
        </div>

        {/* Right column - 1/3 */}
        <div className="flex flex-col gap-4">
          {/* Key Stats */}
          <KeyStatsWidget
            postStats={data.postStats}
            totalIntegrations={data.totalIntegrations}
          />

          {/* Publication Queue */}
          <PublicationQueueWidget upcomingPosts={data.upcomingPosts} />
        </div>
      </div>

      {/* Recent Posts - full width */}
      <RecentPostsWidget recentPosts={data.recentPosts} />
    </div>
  );
};
```

