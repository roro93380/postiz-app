```tsx
'use client';

import { FC } from 'react';
import dayjs from 'dayjs';
import relativeTime from 'dayjs/plugin/relativeTime';
import { DashboardCard } from './dashboard-card';
import ImageWithFallback from '@gitroom/react/helpers/image.with.fallback';

dayjs.extend(relativeTime);

interface RecentPost {
  id: string;
  content: string;
  publishDate: string;
  state: string;
  image?: string | null;
  releaseURL?: string | null;
  integration: {
    id: string;
    name: string;
    providerIdentifier: string;
    picture: string;
  };
}

export const RecentPostsWidget: FC<{
  recentPosts: RecentPost[];
}> = ({ recentPosts }) => {
  return (
    <DashboardCard title="Recent Publications" accentColor="green">
      {recentPosts.length === 0 ? (
        <div className="text-center py-6 text-newTextColor/40 text-[13px]">
          No published posts yet
        </div>
      ) : (
        <div className="flex flex-col gap-2">
          {recentPosts.map((post) => (
            <div
              key={post.id}
              className="flex items-center gap-3 p-2.5 rounded-lg bg-newBgColor/30 border border-newBorder/30 hover:border-newBorder/60 transition-colors group"
            >
              <div className="w-8 h-8 rounded-full overflow-hidden flex-shrink-0">
                <ImageWithFallback
                  src={post.integration.picture}
                  alt={post.integration.name}
                  width={32}
                  height={32}
                  fallbackSrc="/no-picture.png"
                />
              </div>
              <div className="flex-1 min-w-0">
                <p className="text-[13px] text-newTextColor truncate leading-tight">
                  {post.content
                    ? post.content.replace(/<[^>]*>/g, '').slice(0, 60) +
                      (post.content.length > 60 ? '...' : '')
                    : 'Untitled post'}
                </p>
                <div className="flex items-center gap-2 mt-0.5">
                  <span className="text-[10px] text-newTextColor/40 font-medium">
                    {post.integration.name}
                  </span>
                  <span className="text-[10px] text-newTextColor/20">•</span>
                  <span className="text-[10px] text-newTextColor/40">
                    {dayjs(post.publishDate).fromNow()}
                  </span>
                </div>
              </div>
              <div className="flex-shrink-0 flex items-center gap-1">
                <span className="inline-block w-2 h-2 rounded-full bg-[#32d583]" />
                {post.releaseURL && (
                  <a
                    href={post.releaseURL}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="text-newTextColor/30 hover:text-[#00D4FF] transition-colors ml-1"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      )}
    </DashboardCard>
  );
};
```

