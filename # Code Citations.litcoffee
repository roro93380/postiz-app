            releaseURL: true,
            integration: {
              select: {
                id: true,
                name: true,
                providerIdentifier: true,
                picture: true,
              },
            },
          },
        }),
        // Compteurs
        Promise.all([
          this._prisma.model.post.count({
            where: {
              organizationId: orgId,
              state: 'PUBLISHED',
              deletedAt: null,
              parentPostId: null,
              publishDate: { gte: startOfMonth },
            },
          }),
          this._prisma.model.post.count({
            where: {
              organizationId: orgId,
              state: 'QUEUE',
              deletedAt: null,
              parentPostId: null,
            },
          }),
          this._prisma.model.post.count({
            where: {
              organizationId: orgId,
              state: 'DRAFT',
              deletedAt: null,
              parentPostId: null,
            },
          }),
        ]),
        // Intégrations actives
        this._prisma.model.integration.findMany({
          where: {
            organizationId: orgId,
            deletedAt: null,
            disabled: false,
            type: 'social',
          },
          select: {
            id: true,
            name: true,
            providerIdentifier: true,
            picture: true,
          },
        }),
      ]);

    // Posts pour le mini-calendrier (7 prochains jours)
    const weekStart = now.startOf('day').toDate();
    const weekEnd = now.add(6, 'day').endOf('day').toDate();

    const calendarPosts = await this._prisma.model.post.findMany({
      where: {
        organizationId: orgId,
        deletedAt: null,
        parentPostId: null,
        state: { in: ['QUEUE', 'PUBLISHED'] },
        publishDate: { gte: weekStart, lte: weekEnd },
      },
      orderBy: { publishDate: 'asc' },
      select: {
        id: true,
        content: true,
        publishDate: true,
        state: true,
        image: true,
        integration: {
          select: {
            id: true,
            name: true,
            providerIdentifier: true,
            picture: true,
          },
        },
      },
    });

    return {
      upcomingPosts,
      recentPosts,
      calendarPosts,
      postStats: {
        publishedThisMonth: postStats[0],
        queued: postStats[1],
        drafts: postStats[2],
      },
      integrations,
      totalIntegrations: integrations.length,
    };
  }
}
