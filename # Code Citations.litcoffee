interface PostStats {
  publishedThisMonth: number;
  queued: number;
  drafts: number;
}

export const KeyStatsWidget: FC<{
  postStats: PostStats;
  totalIntegrations: number;
}> = ({ postStats, totalIntegrations }) => {
  const stats = [
    {
      label: 'Published',
      value: postStats.publishedThisMonth,
