## 📁 Fichier 8 : MiniCalendar widget
**Créer** : `apps/frontend/src/components/dashboard/widgets/mini-calendar.widget.tsx`

```tsx
'use client';

import { FC, useMemo } from 'react';
import dayjs from 'dayjs';
import Link from 'next/link';
import { DashboardCard } from './dashboard-card';
import ImageWithFallback from '@gitroom/react/helpers/image.with.fallback';

interface CalendarPost {
  id: string;
  content: string;
  publishDate: string;
  state: string;
  image?: string | null;
  integration: {
    id: string;
    name: string;
    providerIdentifier: string;
    picture: string;
  };
}

export const MiniCalendarWidget: FC<{
  calendarPosts: CalendarPost[];
}> = ({ calendarPosts }) => {
  const days = useMemo(() => {
    const result = [];
    const today = dayjs();
    for (let i = 0; i < 7; i++) {
      const day = today.add(i, 'day');
      const postsForDay = calendarPosts.filter((p) =>
        dayjs(p.publishDate).isSame(day, 'day')
      );
      result.push({
        date: day,
        label: day.format('ddd'),
        dayNum: day.format('DD'),
        isToday: i === 0,
        posts: postsForDay,
      });
    }
    return result;
  }, [calendarPosts]);

  return (
    <DashboardCard
      title="Content Calendar"
      accentColor="cyan"
      action={
        <Link
          href="/launches"
          className="text-[12px] text-[#00D4FF] hover:text-[#00D4FF]/80 font-medium transition-colors"
        >
          View full →
        </Link>
      }
    >
      <div className="grid grid-cols-7 gap-1.5">
        {days.map((day) => (
          <div key={day.dayNum} className="flex flex-col items-center">
            <span className="text-[10px] text-newTextColor/40 font-medium mb-1">
              {day.label}
            </span>
            <div
              className={`
                w-full aspect-square rounded-lg border flex flex-col items-center justify-center gap-1 relative overflow-hidden
                ${day.isToday
                  ? 'border-[#00D4FF]/60 bg-[#00D4FF]/5'
                  : 'border-newBorder/50 bg-newBgColor/30'
                }
              `}
            >
              <span
                className={`text-[13px] font-bold ${
                  day.isToday ? 'text-[#00D4FF]' : 'text-newTextColor/70'
                }`}
              >
                {day.dayNum}
              </span>
              {day.posts.length > 0 && (
                <div className="flex -space-x-1">
                  {day.posts.slice(0, 3).map((post) => (
                    <div
                      key={post.id}
                      className="w-4 h-4 rounded-full border border-newBgColorInner overflow-hidden"
                    >
                      <ImageWithFallback
                        src={post.integration.picture}
                        alt={post.integration.name}
                        width={16}
                        height={16}
                        fallbackSrc="/no-picture.png"
                      />
                    </div>
                  ))}
                  {day.posts.length > 3 && (
                    <div className="w-4 h-4 rounded-full bg-[#00D4FF]/20 border border-newBgColorInner flex items-center justify-center">
                      <span className="text-[7px] text-[#00D4FF] font-bold">
                        +{day.posts.length - 3}
                      </span>
                    </div>
                  )}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </DashboardCard>
  );
};
```

